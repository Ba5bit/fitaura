# Solo Scan compare harness — local only. Copy this file to `.env` and fill in.
# `.env` is gitignored, so your keys never get committed.

# A Gemini API key with access to gemini-2.5-flash (and gemini-3.5-flash if the
# same Google project has it enabled). Used for the 2.5 column.
GEMINI_API_KEY=

# Optional: a SEPARATE key for gemini-3.5-flash (e.g. if 3.5 is in another
# project). If left blank, the harness falls back to GEMINI_API_KEY above.
GEMINI_API_KEY_35=
